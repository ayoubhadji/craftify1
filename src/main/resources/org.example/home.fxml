<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.HomeController"
            prefWidth="900.0" prefHeight="600.0"
            style="-fx-background-color: #121212;">

    <!-- TopBar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-padding: 15; -fx-background-color: #1e1e1e;">
            <Label text="🏠 Craftify" style="-fx-text-fill: #ffffff; -fx-font-size: 20px; -fx-font-weight: bold;">
                <font>
                    <Font name="Segoe UI Bold" size="20.0" />
                </font>
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
            <Button onAction="#goToProfile" text="👤 Profil"
                    style="-fx-background-color: #2c2c2c; -fx-text-fill: #00adb5; -fx-background-radius: 8;" />
            <Button onAction="#logout" text="🚪 Déconnexion"
                    style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 8;" />
        </HBox>
    </top>

    <!-- Centre -->
    <center>
        <VBox alignment="CENTER" spacing="30"
              style="-fx-padding: 50; -fx-background-color: #121212;">
            <Label text="Bienvenue sur le FrontOffice ! 🎨"
                   style="-fx-font-size: 24px; -fx-text-fill: #f0f0f0; -fx-font-weight: bold;" />

            <Button onAction="#goToUsers" text="👥 Voir les utilisateurs"
                    style="-fx-background-color: #00adb5; -fx-text-fill: #121212; -fx-font-size: 16px; -fx-background-radius: 10; -fx-padding: 10 20;" />
        </VBox>
    </center>
</BorderPane>
