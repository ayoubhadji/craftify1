<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="controllers.user.UserController" prefWidth="600" prefHeight="400"
            style="-fx-background-color: #f8f8f8;">
    <children>
        <VBox alignment="TOP_CENTER" spacing="30"
              AnchorPane.topAnchor="30.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0">

            <Label text="Mon Profil"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

            <GridPane hgap="10" vgap="20"
                      style="-fx-background-color: #ffffff; -fx-padding: 25px; -fx-border-radius: 10px; -fx-background-radius: 10px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                <columnConstraints>
                    <ColumnConstraints halignment="RIGHT"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Nom complet :" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label fx:id="nameLabel" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Email :" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label fx:id="emailLabel" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Rôle :" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Label fx:id="roleLabel" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            </GridPane>

            <Button fx:id="backButton" text="Retour à l'accueil"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8px; -fx-padding: 8px 20px;" />
        </VBox>
    </children>
</AnchorPane>
